{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mcaffeinenewdash",
  "compatibility_date": "2025-06-01",
  // Static SPA: serve the built dist/ as assets, fall back to index.html for
  // client-side routes. No Worker script needed.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
