# mcAFFEINE dashboard — environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# In production these live in GitHub Secrets, not in the repo.

# Probe42 — live MCA financials for private companies (P0/P2 deep numbers).
# Test key was shared by the client in "Probe42 API and Password - Sheet1.csv".
PROBE42_API_KEY=
# Optional overrides (defaults shown):
# PROBE42_BASE_URL=https://api.probe42.in
# PROBE42_ENV=sandbox            # sandbox | prod
# PROBE42_API_VERSION=1.3
# PROBE42_KEY_HEADER=x-api-key   # header name for the key, if the account differs
# PROBE42_VERSION_HEADER=x-api-version

# Firecrawl — scrapes marketplace/review pages (competitor prices, ratings).
FIRECRAWL_API_KEY=

# OpenAI / LLM — turns messy text (reviews, PDFs) into clean structured insights.
OPENAI_API_KEY=

# Tracxn — no API on the current plan; login is OTP-per-session.
# Near term we use the Drive snapshot, so these are optional/for later scraping.
TRACXN_EMAIL=
TRACXN_PASSWORD=
